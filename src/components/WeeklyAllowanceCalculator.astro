<section class="calculator-panel" aria-labelledby="weekly-pay-calculator-title">
  <div class="calculator-head">
    <p class="eyebrow">2026 기준</p>
    <h2 id="weekly-pay-calculator-title">주휴수당 계산기</h2>
    <p>2026년 최저시급 10,320원을 기본값으로 적용했습니다.</p>
  </div>

  <div class="calculator-grid">
    <form class="calculator-form" id="weeklyAllowanceForm">
      <label class="field">
        <span>시급</span>
        <input id="hourlyWage" type="number" min="0" step="10" value="10320" inputmode="numeric" />
        <small>2026년 최저시급은 10,320원입니다.</small>
      </label>

      <fieldset class="weekday-field">
        <legend>근무 요일</legend>
        <div class="weekday-options">
          <label><input type="checkbox" name="workDay" value="mon" checked /> 월</label>
          <label><input type="checkbox" name="workDay" value="tue" checked /> 화</label>
          <label><input type="checkbox" name="workDay" value="wed" checked /> 수</label>
          <label><input type="checkbox" name="workDay" value="thu" checked /> 목</label>
          <label><input type="checkbox" name="workDay" value="fri" checked /> 금</label>
          <label><input type="checkbox" name="workDay" value="sat" /> 토</label>
          <label><input type="checkbox" name="workDay" value="sun" /> 일</label>
        </div>
      </fieldset>

      <label class="field">
        <span>선택한 요일의 하루 근무시간</span>
        <input id="dailyHours" type="number" min="0" max="24" step="0.5" value="8" inputmode="decimal" />
        <small>요일마다 근무시간이 다르면 주 총 근무시간을 직접 입력하세요.</small>
      </label>

      <label class="field">
        <span>주 총 근무시간 직접 입력</span>
        <input id="weeklyHours" type="number" min="0" max="168" step="0.5" inputmode="decimal" placeholder="비워두면 요일 x 하루 근무시간으로 계산" />
      </label>

      <label class="check-field">
        <input id="perfectAttendance" type="checkbox" checked />
        <span>이번 주 정해진 근무일을 개근했습니다.</span>
      </label>

      <button class="calculator-button" type="submit">주휴수당 계산하기</button>
    </form>

    <div class="calculator-result" aria-live="polite">
      <p class="result-label">이번 주 예상 주휴수당</p>
      <strong id="weeklyAllowanceResult">82,560원</strong>
      <dl>
        <div>
          <dt>주 근무일수</dt>
          <dd id="workDaysResult">5일</dd>
        </div>
        <div>
          <dt>주 총 근무시간</dt>
          <dd id="weeklyHoursResult">40시간</dd>
        </div>
        <div>
          <dt>유급 주휴시간</dt>
          <dd id="paidHolidayHoursResult">8시간</dd>
        </div>
        <div>
          <dt>근로수당</dt>
          <dd id="workPayResult">412,800원</dd>
        </div>
        <div>
          <dt>주급 합계</dt>
          <dd id="weeklyTotalResult">495,360원</dd>
        </div>
        <div>
          <dt>월 환산 주휴수당</dt>
          <dd id="monthlyAllowanceResult">358,783원</dd>
        </div>
      </dl>
      <p id="eligibilityMessage" class="result-note">주 15시간 이상 및 개근 조건을 충족하면 주휴수당이 발생합니다.</p>
    </div>
  </div>
</section>

<script>
  (() => {
    const form = document.getElementById("weeklyAllowanceForm");
    if (!form) return;

    const calculatorForm = form as HTMLFormElement;
    const formatWon = (value: number) => `${Math.round(value).toLocaleString("ko-KR")}원`;
    const formatHours = (value: number) => `${Number(value.toFixed(2)).toLocaleString("ko-KR")}시간`;

    const fields = {
      hourlyWage: document.getElementById("hourlyWage") as HTMLInputElement,
      dailyHours: document.getElementById("dailyHours") as HTMLInputElement,
      weeklyHours: document.getElementById("weeklyHours") as HTMLInputElement,
      perfectAttendance: document.getElementById("perfectAttendance") as HTMLInputElement,
      weeklyAllowanceResult: document.getElementById("weeklyAllowanceResult") as HTMLElement,
      workDaysResult: document.getElementById("workDaysResult") as HTMLElement,
      weeklyHoursResult: document.getElementById("weeklyHoursResult") as HTMLElement,
      paidHolidayHoursResult: document.getElementById("paidHolidayHoursResult") as HTMLElement,
      workPayResult: document.getElementById("workPayResult") as HTMLElement,
      weeklyTotalResult: document.getElementById("weeklyTotalResult") as HTMLElement,
      monthlyAllowanceResult: document.getElementById("monthlyAllowanceResult") as HTMLElement,
      eligibilityMessage: document.getElementById("eligibilityMessage") as HTMLElement
    };

    function calculate() {
      const wage = Math.max(Number(fields.hourlyWage.value) || 0, 0);
      const checkedDays = [...calculatorForm.querySelectorAll<HTMLInputElement>('input[name="workDay"]:checked')];
      const workDays = checkedDays.length;
      const dailyHours = Math.max(Number(fields.dailyHours.value) || 0, 0);
      const manualWeeklyHours = Number(fields.weeklyHours.value);
      const weeklyHours = fields.weeklyHours.value === ""
        ? workDays * dailyHours
        : Math.max(manualWeeklyHours || 0, 0);
      const attended = fields.perfectAttendance.checked;
      const eligible = wage > 0 && weeklyHours >= 15 && attended;
      const paidHolidayHours = eligible ? Math.min((weeklyHours / 40) * 8, 8) : 0;
      const allowance = wage * paidHolidayHours;
      const workPay = wage * weeklyHours;
      const weeklyTotal = workPay + allowance;
      const monthlyAllowance = allowance * 4.345;

      fields.weeklyAllowanceResult.textContent = formatWon(allowance);
      fields.workDaysResult.textContent = `${workDays}일`;
      fields.weeklyHoursResult.textContent = formatHours(weeklyHours);
      fields.paidHolidayHoursResult.textContent = formatHours(paidHolidayHours);
      fields.workPayResult.textContent = formatWon(workPay);
      fields.weeklyTotalResult.textContent = formatWon(weeklyTotal);
      fields.monthlyAllowanceResult.textContent = formatWon(monthlyAllowance);
      fields.eligibilityMessage.textContent = eligible
        ? "주 15시간 이상 및 개근 조건을 충족해 주휴수당 계산 대상입니다."
        : "주 15시간 미만이거나 개근 조건을 충족하지 않으면 주휴수당이 발생하지 않을 수 있습니다.";
    }

    calculatorForm.addEventListener("submit", (event) => {
      event.preventDefault();
      calculate();
    });
    calculatorForm.addEventListener("input", calculate);
    calculatorForm.addEventListener("change", calculate);
    calculate();
  })();
</script>
