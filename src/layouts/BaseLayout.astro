---
import "../styles/global.css";

const {
  title = "SsangBak",
  description = "지원금, 정부정책, 생활정보, 엔터·스포츠 이슈를 빠르게 확인할 수 있는 실용 정보 아카이브입니다.",
  canonical,
  robots = "index, follow, max-image-preview:large"
} = Astro.props;

const site = Astro.site ?? new URL("https://ssangbak.com");
const canonicalUrl = canonical ? new URL(canonical, site).toString() : Astro.url.toString();
const primaryNav = [
  { href: "/category/subsidy/", label: "정부지원정책" },
  { href: "/category/living-information/", label: "생활정보" },
  { href: "/category/entertainment-sports/", label: "엔터&스포츠" },
  { href: "/weekly-holiday-allowance-calculator/", label: "계산기" }
];
const breakingHref = "/lim-youngwoong-concert-ticket/";
const breakingText = "2026 임영웅 콘서트 티켓오픈 7월 16일 오후 8시";
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="SsangBak RSS" href="/rss.xml" />
    <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4041977310641067" crossorigin="anonymous"></script>
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SsangBak" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="masthead">
        <a class="brand" href="/" aria-label="SsangBak 홈">
          <img src="/logo.png" alt="SsangBak" width="720" height="783" />
        </a>
        <nav class="nav" aria-label="주요 메뉴">
          <div class="nav-links">
            {primaryNav.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))}
          </div>
        </nav>
        <details class="mobile-menu">
          <summary aria-label="카테고리 메뉴 열기">
            <span></span>
            <span></span>
            <span></span>
          </summary>
          <div class="mobile-menu-panel" aria-label="모바일 카테고리 메뉴">
            {primaryNav.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))}
          </div>
        </details>
        <a class="search-link" href="/sitemap.xml" aria-label="사이트 전체 글 보기">⌕</a>
      </div>
      <div class="ticker-bar">
        <div class="ticker-inner">
          <a class="ticker-badge" href={breakingHref}>속보</a>
          <a class="ticker-title" href={breakingHref}>{breakingText}</a>
          <div class="ticker-controls" aria-hidden="true">
            <span>&lt;</span>
            <span>&gt;</span>
          </div>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <strong>SsangBak</strong>
      <span>© 2026. 실용 정보 아카이브.</span>
    </footer>
  </body>
</html>
