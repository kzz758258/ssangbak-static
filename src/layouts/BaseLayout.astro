---
import "../styles/global.css";
import { CATEGORIES } from "../lib/taxonomy";

const {
  title = "SsangBak",
  description = "지원금, 정책, 금융, 공연, 생활정보를 정리하는 실용 정보 사이트입니다.",
  canonical,
  robots = "index, follow, max-image-preview:large"
} = Astro.props;

const site = Astro.site ?? new URL("https://ssangbak.com");
const canonicalUrl = canonical ? new URL(canonical, site).toString() : Astro.url.toString();
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="SsangBak RSS" href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SsangBak" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="주요 메뉴">
        <a class="brand" href="/">SsangBak</a>
        <div class="nav-links">
          {CATEGORIES.map((category) => (
            <a href={`/category/${category.slug}/`}>{category.title}</a>
          ))}
        </div>
      </nav>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">© 2026 SsangBak</footer>
  </body>
</html>
