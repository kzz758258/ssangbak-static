---
import BaseLayout from "./BaseLayout.astro";

const { post } = Astro.props;
const { Content } = await post.render();
const title = `${post.data.title} | SsangBak`;
const description = post.data.description ?? post.data.title;
---

<BaseLayout title={title} description={description} canonical={post.data.permalink}>
  <article class="article">
    <h1>{post.data.title}</h1>
    <p class="meta">
      <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("ko-KR")}</time>
    </p>
    {post.data.heroImage && <img src={post.data.heroImage} alt={post.data.title} loading="eager" />}
    <Content />
  </article>
</BaseLayout>
