---
import BaseLayout from "./BaseLayout.astro";
import AdSlot from "../components/AdSlot.astro";
import WeeklyAllowanceCalculator from "../components/WeeklyAllowanceCalculator.astro";
import { absoluteUrl, buildMetaDescription, slugifyHeading } from "../lib/seo";
import { getRelatedPosts, inferCategory } from "../lib/taxonomy";

const { post, allPosts = [] } = Astro.props;
const { Content, headings } = await post.render();
const category = inferCategory(post);
const relatedPosts = getRelatedPosts(post, allPosts, 6);
const latestPosts = [...allPosts]
  .filter((candidate: any) => candidate.id !== post.id)
  .sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
const title = `${post.data.title} | SsangBak`;
const description = buildMetaDescription(post.data.title, post.data.description, category.title);
const site = Astro.site ?? new URL("https://ssangbak.com");
const canonicalUrl = absoluteUrl(post.data.permalink, site);
const imageUrl = absoluteUrl(post.data.heroImage, site);
const published = post.data.pubDate.toISOString();
const modified = (post.data.updatedDate ?? post.data.pubDate).toISOString();
const isWeeklyAllowanceCalculator = post.data.slugPath === "weekly-holiday-allowance-calculator";

type RenderedHeading = {
  depth: number;
  slug?: string;
  text: string;
};

const tocHeadings = (headings as RenderedHeading[])
  .filter((heading: RenderedHeading) => heading.depth === 2 || heading.depth === 3)
  .map((heading: RenderedHeading) => ({
    ...heading,
    slug: heading.slug || slugifyHeading(heading.text)
  }));

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description,
  datePublished: published,
  dateModified: modified,
  mainEntityOfPage: canonicalUrl,
  image: imageUrl ? [imageUrl] : undefined,
  articleSection: category.title,
  author: {
    "@type": "Organization",
    name: "SsangBak"
  },
  publisher: {
    "@type": "Organization",
    name: "SsangBak"
  }
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "홈",
      item: absoluteUrl("/", site)
    },
    {
      "@type": "ListItem",
      position: 2,
      name: category.title,
      item: absoluteUrl(`/category/${category.slug}/`, site)
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: canonicalUrl
    }
  ]
};
---

<BaseLayout title={title} description={description} canonical={post.data.permalink}>
  <Fragment slot="head">
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta property="og:type" content="article" />
    <meta property="article:section" content={category.title} />
    <meta property="article:published_time" content={published} />
    <meta property="article:modified_time" content={modified} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <div class="article-page page-shell">
    <article class="article">
      <nav class="breadcrumb" aria-label="브레드크럼">
        <a href="/">홈</a>
        <span aria-hidden="true">/</span>
        <a href={`/category/${category.slug}/`}>{category.title}</a>
        <span aria-hidden="true">/</span>
        <span>{post.data.title}</span>
      </nav>
      <header class="article-header">
        <h1>{post.data.title}</h1>
        <p class="meta">
          <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("ko-KR")}</time>
        </p>
        {description && <p class="article-summary">{description}</p>}
      </header>
      {post.data.heroImage && <img class="hero-image" src={post.data.heroImage} alt={post.data.title} loading="eager" />}
      {isWeeklyAllowanceCalculator && <WeeklyAllowanceCalculator />}
      {tocHeadings.length > 1 && (
        <nav class="toc" aria-label="본문 목차">
          <p class="toc-title">본문 목차</p>
          <ol>
            {tocHeadings.map((heading: RenderedHeading) => (
              <li class={`toc-depth-${heading.depth}`}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )}
      {tocHeadings.length > 1 && (
        <AdSlot slot="6912814701" label="목차 다음 광고" className="ad-placement--article" />
      )}
      <Content />
      <AdSlot
        slot="1475434001"
        label="자주 묻는 질문 전 광고"
        className="ad-placement--article"
        moveBeforeFaq
      />
      {relatedPosts.length > 0 && (
        <section class="related-posts" aria-label="함께 보면 좋은 글">
          <div class="section-head">
            <p class="section-kicker">Related</p>
            <h2>함께 보면 좋은 글</h2>
          </div>
          <div class="related-grid">
            {relatedPosts.map((related: any) => (
              <a class="related-card" href={related.data.permalink}>
                {related.data.heroImage && <img src={related.data.heroImage} alt="" loading="lazy" />}
                <span>{inferCategory(related).title}</span>
                <strong>{related.data.title}</strong>
              </a>
            ))}
          </div>
        </section>
      )}
    </article>
    {latestPosts.length > 0 && (
      <aside class="article-sidebar" aria-labelledby="article-sidebar-title">
        <div class="sidebar-sticky">
          <div class="sidebar-head">
            <h2 id="article-sidebar-title">최신 뉴스</h2>
          </div>
          <div class="sidebar-list">
            {latestPosts.map((latest: any) => (
              <a class="sidebar-item" href={latest.data.permalink}>
                {latest.data.heroImage && <img src={latest.data.heroImage} alt="" loading="lazy" />}
                <span>{latest.data.title}</span>
              </a>
            ))}
          </div>
        </div>
      </aside>
    )}
  </div>
</BaseLayout>
