---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const categories = [
    { slug: "subsidy", title: "지원금" },
    { slug: "living-information", title: "생활정보" },
    { slug: "broadcasting", title: "방송" },
    { slug: "ai-job", title: "AI 직업" },
    { slug: "concert-musical", title: "콘서트·뮤지컬" },
    { slug: "ai-stocks", title: "AI 주식" }
  ];

  return categories.map((category) => ({
    params: { slug: category.slug },
    props: { category }
  }));
}

const { category } = Astro.props;
const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title={`${category.title} | SsangBak`} description={`${category.title} 글 목록입니다.`}>
  <section class="post-list" aria-label={`${category.title} 글 목록`}>
    <nav class="breadcrumb" aria-label="브레드크럼">
      <a href="/">홈</a>
      <span aria-hidden="true">/</span>
      <span>{category.title}</span>
    </nav>
    <h1>{category.title}</h1>
    {posts.map((post) => (
      <article class="post-card">
        <h2><a href={post.data.permalink}>{post.data.title}</a></h2>
        <p class="meta">{post.data.pubDate.toLocaleDateString("ko-KR")}</p>
        {post.data.description && <p>{post.data.description}</p>}
      </article>
    ))}
  </section>
</BaseLayout>
