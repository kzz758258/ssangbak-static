---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { CATEGORIES, inferCategory } from "../lib/taxonomy";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPosts = posts.slice(0, 4);
const sidePosts = posts.slice(4, 10);
const latestPosts = posts.slice(10, 34);
const sectionPosts = CATEGORIES.map((category) => ({
  category,
  posts: posts.filter((post) => inferCategory(post).slug === category.slug).slice(0, 4)
})).filter((section) => section.posts.length > 0);
---

<BaseLayout title="SsangBak | 지원금·생활정보·엔터스포츠" description="지원금과 정부정책, 생활정보, 콘서트 예매와 스포츠 중계까지 지금 필요한 정보를 빠르게 정리하는 SsangBak입니다.">
  <section class="magazine-section page-shell" aria-labelledby="home-title">
    <div class="magazine-head">
      <h1 id="home-title">오늘의 핵심</h1>
      <p>지원금, 생활정보, 콘서트 예매와 스포츠 중계까지 바로 확인할 수 있게 정리합니다.</p>
    </div>
    <div class="magazine-layout">
      <div class="feature-grid">
        {featuredPosts.map((post, index) => (
          <article class="feature-card">
            {post.data.heroImage && <img src={post.data.heroImage} alt="" loading={index === 0 ? "eager" : "lazy"} />}
            <span>{inferCategory(post).title}</span>
            <h2><a href={post.data.permalink}>{post.data.title}</a></h2>
            <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("ko-KR")}</time>
          </article>
        ))}
      </div>
      <aside class="side-news" aria-labelledby="side-news-title">
        <h2 id="side-news-title">빠른 체크</h2>
        <div class="side-news-list">
          {sidePosts.map((post) => (
            <article class="side-news-item">
              <div>
                <h3><a href={post.data.permalink}>{post.data.title}</a></h3>
                <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("ko-KR")}</time>
              </div>
              {post.data.heroImage && <img src={post.data.heroImage} alt="" loading="lazy" />}
            </article>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="section-block page-shell" aria-labelledby="latest-title">
    <div class="section-head">
      <p class="section-kicker">Latest</p>
      <h2 id="latest-title">최신 업데이트</h2>
    </div>
    <div class="news-list">
      {latestPosts.map((post) => (
        <article class="news-item">
          {post.data.heroImage && <img src={post.data.heroImage} alt="" loading="lazy" />}
          <div>
            <span>{inferCategory(post).title}</span>
            <h3><a href={post.data.permalink}>{post.data.title}</a></h3>
            {post.data.description && <p>{post.data.description}</p>}
            <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("ko-KR")}</time>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block page-shell" aria-labelledby="category-digest-title">
    <div class="section-head">
      <p class="section-kicker">Sections</p>
      <h2 id="category-digest-title">분야별 주요 글</h2>
    </div>
    <div class="section-digest">
      {sectionPosts.map(({ category, posts }) => (
        <section class="digest-card" aria-labelledby={`${category.slug}-title`}>
          <div class="digest-head">
            <h3 id={`${category.slug}-title`}><a href={`/category/${category.slug}/`}>{category.title}</a></h3>
            <p>{category.description}</p>
          </div>
          <div class="digest-list">
            {posts.map((post) => (
              <a href={post.data.permalink}>
                {post.data.heroImage && <img src={post.data.heroImage} alt="" loading="lazy" />}
                <span>{post.data.title}</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
