---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { CATEGORIES, inferCategory } from "../lib/taxonomy";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const heroPost = posts[0];
const heroGridPosts = posts.slice(1, 5);
const latestPosts = posts.slice(5, 10);
const sectionPosts = CATEGORIES.map((category) => ({
  category,
  posts: posts.filter((post) => inferCategory(post).slug === category.slug).slice(0, 6)
})).filter((section) => section.posts.length > 0);
---

<BaseLayout title="SsangBak | 지원금·생활정보·엔터스포츠" description="지원금과 정부정책, 생활정보, 콘서트 예매와 스포츠 중계까지 지금 필요한 정보를 빠르게 정리하는 SsangBak입니다.">
  <section class="home-top-section page-shell" aria-label="주요 정보">
    <div class="top-story-layout">
      <div class="top-story-grid">
        {heroPost && (
          <article class="top-story-card top-story-card-large">
            {heroPost.data.heroImage && <img src={heroPost.data.heroImage} alt="" loading="eager" />}
            <a class="top-story-link" href={heroPost.data.permalink} aria-label={heroPost.data.title}></a>
          </article>
        )}
        <div class="top-story-small-grid">
          {heroGridPosts.map((post) => (
            <article class="top-story-card">
              {post.data.heroImage && <img src={post.data.heroImage} alt="" loading="lazy" />}
              <a class="top-story-link" href={post.data.permalink} aria-label={post.data.title}></a>
            </article>
          ))}
        </div>
      </div>

      <aside class="side-news home-latest" aria-labelledby="latest-news-title">
        <h2 id="latest-news-title">최신 정보</h2>
        <div class="side-news-list">
          {latestPosts.map((post) => (
            <article class="side-news-item">
              <div>
                <h3><a href={post.data.permalink}>{post.data.title}</a></h3>
                <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("ko-KR")}</time>
              </div>
              {post.data.heroImage && <img src={post.data.heroImage} alt="" loading="lazy" />}
            </article>
          ))}
        </div>
      </aside>
    </div>
  </section>

  {sectionPosts.map(({ category, posts }) => (
    <section class="category-feature-section page-shell" aria-labelledby={`${category.slug}-home-title`}>
      <div class="category-feature-head">
        <h2 id={`${category.slug}-home-title`}><a href={`/category/${category.slug}/`}>{category.title}</a></h2>
      </div>
      <div class="quick-check-grid">
        {posts.slice(0, 6).map((post) => (
          <article class="quick-check-card">
            {post.data.heroImage && <img src={post.data.heroImage} alt="" loading="lazy" />}
            <div>
              <span>{category.title}</span>
              <h3><a href={post.data.permalink}>{post.data.title}</a></h3>
              <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("ko-KR")}</time>
            </div>
          </article>
        ))}
      </div>
      <a class="category-more-link" href={`/category/${category.slug}/`}>자세히 알아보기</a>
    </section>
  ))}
</BaseLayout>
